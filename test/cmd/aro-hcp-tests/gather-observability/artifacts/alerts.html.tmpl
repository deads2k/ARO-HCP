<html>
<head>
  <title>Azure Monitor Alerts</title>
  <meta name="description" content="Azure Monitor alerts fired during e2e test run.">
  <link rel="stylesheet" type="text/css" href="/static/style.css">
  <link rel="stylesheet" type="text/css" href="/static/extensions/style.css">
  <link href="https://fonts.googleapis.com/css?family=Roboto:400,700" rel="stylesheet">
  <link rel="stylesheet" href="https://code.getmdl.io/1.3.0/material.indigo-pink.min.css">
  <link rel="stylesheet" type="text/css" href="/static/spyglass/spyglass.css">
  <style>
    body {
      background-color: #0d1117;
      color: #e6edf3;
      font-family: 'Roboto', -apple-system, sans-serif;
      margin: 0;
      padding: 16px 24px;
    }

    /* --- Summary bar --- */
    .summary-bar {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      align-items: center;
      margin: 12px 0 24px 0;
    }
    .badge {
      display: inline-block;
      padding: 4px 12px;
      border-radius: 3px;
      font-weight: 700;
      font-size: 13px;
      text-transform: uppercase;
      letter-spacing: 0.3px;
    }
    .severity-critical { background-color: #da3633; color: #fff; }
    .severity-error    { background-color: #d29922; color: #000; }
    .severity-warning  { background-color: #d29922; color: #000; }
    .severity-info     { background-color: #316dca; color: #fff; }
    .severity-verbose  { background-color: #484f58; color: #e6edf3; }
    .badge-known       { background-color: #9e6a03; color: #fff; }
    .badge-unknown     { background-color: #da3633; color: #fff; }

    .meta {
      color: #8b949e;
      font-size: 13px;
      margin-bottom: 4px;
    }
    .meta span { margin-right: 20px; }

    /* --- Section headers --- */
    .section-header {
      font-size: 15px;
      font-weight: 700;
      margin: 28px 0 10px 0;
      padding: 8px 14px;
      border-radius: 4px;
    }
    .section-header-unknown { background-color: #da3633; }
    .section-header-known   { background-color: #9e6a03; }

    .no-alerts {
      color: #3fb950;
      font-size: 18px;
      padding: 24px;
      text-align: center;
    }

    /* --- Alert cards --- */
    .alert-card {
      background-color: #161b22;
      border: 1px solid #30363d;
      border-radius: 6px;
      padding: 16px 20px;
      margin: 10px 0;
      border-left: 4px solid #da3633;
    }
    .alert-card-known {
      border-left-color: #9e6a03;
      opacity: 0.8;
    }

    /* Top row: badges + condition + cluster + time */
    .alert-header {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
      margin-bottom: 8px;
    }
    .alert-header .badge { padding: 2px 8px; font-size: 12px; }

    .condition-fired    { color: #f85149; font-weight: 700; }
    .condition-resolved { color: #3fb950; font-weight: 700; }

    .alert-cluster {
      color: #8b949e;
      font-size: 13px;
    }
    .alert-cluster strong {
      color: #c9d1d9;
    }
    .alert-time {
      color: #8b949e;
      font-size: 13px;
      margin-left: auto;
    }

    /* Alert title */
    .alert-title {
      font-size: 15px;
      font-weight: 700;
      margin-bottom: 6px;
      color: #e6edf3;
    }

    /* Description */
    .alert-description {
      font-size: 14px;
      line-height: 1.6;
      color: #c9d1d9;
      margin-bottom: 8px;
    }

    /* Known issue reason */
    .known-reason {
      font-size: 13px;
      color: #d29922;
      margin-bottom: 8px;
      padding: 6px 10px;
      background: rgba(158, 106, 3, 0.15);
      border-radius: 4px;
      border-left: 3px solid #9e6a03;
    }
    .known-reason strong {
      text-transform: uppercase;
      letter-spacing: 0.3px;
      font-size: 11px;
    }

    /* Labels grid */
    .alert-labels {
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
      margin-top: 8px;
    }
    .alert-labels .label-chip {
      display: inline-block;
      background: #21262d;
      border: 1px solid #30363d;
      padding: 2px 8px;
      border-radius: 3px;
      font-size: 12px;
      color: #8b949e;
      font-family: monospace;
    }
    .alert-labels .label-chip .label-key {
      color: #58a6ff;
    }

    /* Collapsible PromQL */
    details.query-details {
      margin-top: 8px;
    }
    details.query-details summary {
      cursor: pointer;
      font-size: 12px;
      color: #58a6ff;
      user-select: none;
      padding: 4px 0;
    }
    details.query-details summary:hover {
      text-decoration: underline;
    }
    .alert-expr {
      font-family: monospace;
      font-size: 12px;
      color: #8b949e;
      background: #0d1117;
      border: 1px solid #30363d;
      padding: 10px 12px;
      border-radius: 4px;
      margin-top: 6px;
      white-space: pre-wrap;
      word-break: break-all;
      line-height: 1.5;
    }

    /* Runbook link */
    .alert-links {
      margin-top: 8px;
    }
    .alert-links a {
      font-size: 12px;
      color: #58a6ff;
      text-decoration: none;
    }
    .alert-links a:hover {
      text-decoration: underline;
    }
  </style>
</head>

<body>

  <div class="meta">
    <span>Time window: {{.TimeWindow.Start}} &mdash; {{.TimeWindow.End}}</span>
    <span>Scope: {{.Scope}}</span>
  </div>

  {{if .HasAlerts}}
  <div class="summary-bar">
    {{range $sev, $count := .SeverityCounts}}
    <span class="badge {{severityClass $sev}}">{{$sev}}: {{$count}}</span>
    {{end}}
    <span class="badge badge-unknown">Unknown: {{.UnknownCount}}</span>
    <span class="badge badge-known">Known: {{.KnownCount}}</span>
  </div>

  {{range .Alerts}}
  <div class="alert-card{{if .Metadata.KnownIssue}} alert-card-known{{end}}">
    <div class="alert-header">
      <span class="badge {{severityClass .Alert.Severity}}">{{.Alert.Severity}}</span>
      <span class="{{conditionClass .Alert.Condition}}">{{.Alert.Condition}}</span>
      <span class="alert-time">
        Fired: {{formatTime .Alert.StartsAt}} {{relativeTime $.TimeWindow.Start .Alert.StartsAt}}{{if .Alert.EndsAt}} &middot; Resolved: {{formatTime .Alert.EndsAt}} {{relativeTime $.TimeWindow.Start .Alert.EndsAt}}{{end}}
      </span>
    </div>
    <div class="alert-title">{{.Alert.Name}}</div>
    {{if .Metadata.KnownIssueReason}}
    <div class="known-reason"><strong>Known Issue:</strong> {{.Metadata.KnownIssueReason}}</div>
    {{end}}
    {{if .Alert.Description}}<div class="alert-description">{{.Alert.Description}}</div>{{end}}

    {{if .Alert.Labels}}
    <div class="alert-labels">
      {{range $k, $v := .Alert.Labels}}<span class="label-chip"><span class="label-key">{{$k}}</span>=<span>{{$v}}</span></span>{{end}}
    </div>
    {{end}}

    {{with annotation .Alert.Annotations "runbook_url"}}{{if ne . "TBD"}}
    <div class="alert-links"><a href="{{.}}" target="_blank" rel="noopener">View Runbook &rarr;</a></div>
    {{end}}{{end}}

    {{if .Alert.Expression}}
    <details class="query-details">
      <summary>View PromQL Query</summary>
      <div class="alert-expr">{{.Alert.Expression}}</div>
    </details>
    {{end}}
  </div>
  {{end}}

  {{if not .HasUnknownAlerts}}
  <div class="no-alerts">No unknown alerts. All {{.KnownCount}} alerts matched known issues.</div>
  {{end}}

  {{else}}
  <div class="no-alerts">No alerts fired during the test window.</div>
  {{end}}

  <!-- workaround for spyglass cutting off page bottoms -->
  <div style="height: 20px;"></div>
</body>
</html>
